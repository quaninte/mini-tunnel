# Generated by bin/render.sh — do not edit by hand; edit the deployment .env + this template.
# Deployment: {{DEPLOY_NAME}}  hostname: {{HOSTNAME}}  status: {{DEPLOY_STATUS}}

# --- HTTP → HTTPS redirect ---
server {
    listen 80;
    listen [::]:80;
    server_name {{HOSTNAME}};
    return 301 https://$host$request_uri;
}

# --- Named upstream (bastion-dev.conf pattern) ---
upstream {{UPSTREAM_NAME}} {
    server {{UPSTREAM_HOST}}:{{UPSTREAM_PORT}};
    keepalive 8;
}

# --- HTTPS vhost ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{HOSTNAME}};

    ssl_certificate     /etc/letsencrypt/live/{{SSL_CERT}}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{SSL_CERT}}/privkey.pem;

    # Per-host logs
    access_log /usr/local/openresty/nginx/logs/{{DEPLOY_NAME}}.access.log;
    error_log  /usr/local/openresty/nginx/logs/{{DEPLOY_NAME}}.error.log;

    # Server-scoped realip (POST_READ). NEVER put these at http level —
    # this box fronts ~200 vhosts and global scope would rewrite $remote_addr for all.
    # Stale CF ranges fail closed: edge IPs won't match ALLOW_CIDRS.
{{REAL_IP_BLOCK}}
    real_ip_header CF-Connecting-IP;
    real_ip_recursive on;

    # Allow/deny gate (ACCESS phase; sees true client IP after realip).
    # Bare directives at server level — house convention (frp-server.conf:110).
{{ALLOW_BLOCK}}
    deny all;

{{OAUTH2_BLOCK}}
    location / {
{{AUTH_REQUEST_BLOCK}}
        proxy_pass http://{{UPSTREAM_NAME}};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # WebSocket upgrade (openchamber needs these; leanflag-openwebui.conf pattern)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
