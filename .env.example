# Authentication
PASS_KEY=

# Bind address for LAN-facing services (openchamber, OpenWebUI).
# Default 127.0.0.1 preserves historical loopback-only behavior when unset.
# Set to the dev server's internal IP (e.g. 10.29.0.x) when fronting with OpenResty.
# WARNING: non-loopback binds expose services on the LAN (see README "LAN exposure").
# opencode always stays on 127.0.0.1 — it is a backend and must never be LAN-reachable.
BIND_ADDR=127.0.0.1

# Cloudflare Tunnel (DEPRECATED — default off; prefer OpenResty origin routing)
# Set ENABLE_CF_TUNNEL=true only for legacy tunnel mode. Existing .env without
# this key will NOT start cloudflared (breaking change; intentional).
ENABLE_CF_TUNNEL=false
# Deprecated: only used when ENABLE_CF_TUNNEL=true
CF_TUNNEL_TOKEN=
# Deprecated: public hostname for the tunnel path; OpenResty uses deployments/*.env HOSTNAME
CF_HOSTNAME=quinmini.leanflag.net

# Ports
OPENCODE_PORT=4096
OPENCHAMBER_PORT=3000

# OpenCode/OpenChamber profile. Defaults to .opencode-profile/ in this
# checkout; use a private persistent mount if deployments replace the clone.
OPENCODE_PROFILE_DIR=

# Stacks (enable one or both)
ENABLE_CODE_STACK=true
ENABLE_OPENWEBUI=false

# OpenWebUI (only used when ENABLE_OPENWEBUI=true)
OPENWEBUI_PORT=8080
OPENWEBUI_TAG=main
OPENWEBUI_HOSTNAME=
OPENWEBUI_SECRET_KEY=
# Deprecated: only used when ENABLE_CF_TUNNEL=true and OpenWebUI has its own tunnel token.
# Leave empty if OPENWEBUI_HOSTNAME is a second Public Hostname rule on the same tunnel.
OPENWEBUI_CF_TUNNEL_TOKEN=
