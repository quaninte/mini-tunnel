# chat-alphascout — lean OpenChamber on lo, fronted by OpenResty + oauth2
DEPLOY_NAME=chat-alphascout
DEPLOY_STATUS=active

HOSTNAME=chat-alphascout.leanflag.net
CF_ZONE=leanflag.net

# Cloudflare API token via local 1Password only (never on lo)
CF_TOKEN_REF=op://DevOps/cloudflare-leanflag-net-dns/credential

CF_PROXIED=true
ORIGIN_IP=123.16.178.142

# lo internal IP as seen from local-sbase-dev-openresty
UPSTREAM_HOST=10.29.0.69
UPSTREAM_PORT=3000

OPENRESTY_HOST=local-sbase-dev-openresty
SSL_CERT=leanflag.net

AUTH_MODE=oauth2

# OAuth2 is the sole public gate; no IP allowlist is configured.
