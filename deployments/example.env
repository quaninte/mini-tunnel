# Fully-commented reference deployment record.
# Copy to deployments/<name>.env and fill in real values.
# Source of truth for schema: deployments/README.md

# Identity
DEPLOY_NAME=example
# active | pending | decommissioned
# ALLOW_CIDRS is optional: empty/omitted = no IP gate (rely on AUTH_MODE).
# active rejects ALLOW_CIDRS=__FILL_ME__ and empty ALLOW_CIDRS + AUTH_MODE=none.
DEPLOY_STATUS=pending

# Public hostname and Cloudflare zone
# For the committed rendered example (nginx/examples/quinmini.leanflag.net.conf),
# this record uses documentation placeholders only — not a live deployment.
HOSTNAME=quinmini.leanflag.net
CF_ZONE=leanflag.net

# 1Password reference for the Cloudflare API token (multi-account lives here).
# Example shape: op://DevOps/cloudflare-leanflag/credential
# Never put a plaintext token here.
CF_TOKEN_REF=op://__FILL_ME__/__FILL_ME__/credential

# Cloudflare DNS record settings
CF_PROXIED=true
ORIGIN_IP=195.85.88.187

# Upstream: documentation IP only (RFC 5737 / private lab example). Not a real host.
UPSTREAM_HOST=10.29.0.99
UPSTREAM_PORT=3000

# OpenResty apply target (SSH alias) and wildcard cert name under /etc/letsencrypt/live/
OPENRESTY_HOST=local-sbase-dev-openresty
SSL_CERT=leanflag.net

# Auth: oauth2 (auth_request to 127.0.0.1:4180) or none
AUTH_MODE=oauth2

# Optional IP allowlist (space-separated CIDRs). Omit or leave empty for no IP
# gate (OAuth2 alone). Documentation CIDRs only (RFC 5737 TEST-NET-3) here —
# never copy these into a real active deployment; real CIDRs must come from the user.
ALLOW_CIDRS=203.0.113.0/24
